# Push only Apps Script files (Code.gs, pop.gs, appsscript.json).
# Everything else is workshop frontend that does not belong in the script project.

# Workshop HTML pages (NOT HtmlService templates)
**/index.html
**/scene-*.html
**/gallery.html

# Kit assets — these are downloaded by teachers, not run server-side
kit/**

# Frontend assets
css/**
js/**
media/**

# Documentation + config
README.md
.gitignore
.git/**
.clasp.json
.claspignore

# OS / editor / runtime
.DS_Store
**/.DS_Store
.vscode/**
.idea/**
node_modules/**

# Logs / artifacts
*.log
firebase-debug.log
test-results/**
.playwright-mcp/**

# Finder/editor duplicate suffixes — never push these to Apps Script
* 2.*
* [0-9].*
*-copy.*
*.bak
